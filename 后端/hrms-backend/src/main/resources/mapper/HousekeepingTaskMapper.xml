<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.mapper.HousekeepingTaskMapper">
    <!-- 查询清洁任务列表，支持状态和房间筛选 -->
    <select id="selectTaskList" resultType="com.hrms.entity.HousekeepingTask">
        select *
        from housekeeping_task
        <where>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="roomNumber != null and roomNumber != ''">
                and room_number = #{roomNumber}
            </if>
            <if test="assignedTo != null and assignedTo != ''">
                and assigned_to = #{assignedTo}
            </if>
        </where>
        order by id
    </select>
</mapper>
